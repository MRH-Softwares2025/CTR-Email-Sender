# Production environment template
# Copy this file to .env and replace the placeholder values before deployment.

# App environment
APP_ENV=production
DEBUG=false
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO

# Gmail Configuration
GMAIL_EMAIL=your_email@gmail.com
# Optional fallback only; OAuth is recommended for multi-user deployments.
GMAIL_APP_PASSWORD=your_16_char_app_password

# Google OAuth (per-user Gmail authorization)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
# Optional. If omitted, app builds this as: https://<your-domain>/api/oauth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.example.com/api/oauth/google/callback

# Email Settings
# Recipient email is fixed in the application and cannot be changed by users.
RECIPIENT_EMAIL=jesusislord.fmradio@gmail.com
EMAIL_SUBJECT=Jesus is Lord Radio
EMAIL_BODY=Your email body content here\nSecond line of message\nThird line of message

# Scheduling Settings
START_HOUR=00
END_HOUR=17
EMAILS_PER_HOUR=50
TIME_VARIATION_SECONDS=300

# Database backend
# Use sqlite for local dev or firestore for Firebase/Cloud deployments.
DB_BACKEND=firestore

# Firebase / Firestore
# Set DB_BACKEND=firestore and fill these values to use Firebase.
FIREBASE_PROJECT_ID=ctr-email-sender
# Option A: set path to service account file via FIREBASE_SERVICE_ACCOUNT_JSON
FIREBASE_SERVICE_ACCOUNT_JSON=F:\Softwares\My apps\ctr-email-sender-firebase-adminsdk-fbsvc-101bd82dc3.json
# Option B: set GOOGLE_APPLICATION_CREDENTIALS in your host environment.

# MPESA Subscription Settings
# Subscription plans are managed in the database.
# Replace these with your Safaricom Daraja production or sandbox credentials.
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://your-domain.example.com/api/subscription/callback

# Security
SECRET_KEY=replace-with-a-long-random-secret
SESSION_SECURE=true
SESSION_MAX_AGE=1209600
HTTPS_ONLY=true
DISABLE_SUBSCRIPTION_CHECK=false
