# Gmail Configuration
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Email Settings
# Recipient email is fixed in the application and cannot be changed by users.
RECIPIENT_EMAIL=jesusislord.fmradio@gmail.com
EMAIL_SUBJECT=Jesus is Lord Radio
EMAIL_BODY=Your email body content here\nSecond line of message\nThird line of message

# Scheduling Settings
START_HOUR=00
END_HOUR=17
EMAILS_PER_HOUR=50
TIME_VARIATION_SECONDS=300

# MPESA Subscription Settings
# Subscription plans are now managed in the database (subscription_plans table)
# Default plans: Daily (KES 10, 1 day), Weekly (KES 50, 7 days), Fortnightly (KES 80, 14 days), Monthly (KES 100, 30 days)
# Plans are automatically created on first run. Modify plans directly in the database if needed.
# To make payments work, set these values to your Safaricom Daraja app credentials.
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=http://localhost:8001/api/subscription/callback
# If you are testing from a phone or another machine, use a public URL such as:
# MPESA_CALLBACK_URL=https://your-public-domain.ngrok-free.app/api/subscription/callback

# Logging
PORT=8001
LOG_LEVEL=INFO

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
